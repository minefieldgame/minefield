OPENAI_API_KEY=
# Optional override. Defaults to the current configured model in the app.
OPENAI_MODEL=gpt-5.4-mini

# Set a private production value in Amplify. Do not commit the value.
MINEFIELD_ADMIN_PASSWORD=

# Optional DynamoDB overrides. Defaults match the production table names.
AWS_REGION=us-east-1
MINEFIELD_DAILY_CONTENT_TABLE=MinefieldDailyContent
MINEFIELD_USED_CONTENT_TABLE=MinefieldUsedContent
